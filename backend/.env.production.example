# =============================================================================
# backend/.env.production.example
# Copy this to /root/job-tracker-v2/.env on the Droplet and fill in values.
# Never commit the real .env file.
# =============================================================================

# DATABASE_URL — Supabase pooled connection string (port 6543, PgBouncer)
# Used by FastAPI at runtime. Do NOT use the direct connection here.
# Format: postgresql://postgres:[password]@[host]:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[password]@[host]:6543/postgres?sslmode=require

# DATABASE_URL_DIRECT — Supabase direct connection string (port 5432)
# Used by Alembic migrations only. Never used at runtime.
# Format: postgresql://postgres:[password]@[host]:5432/postgres?sslmode=require
DATABASE_URL_DIRECT=postgresql://postgres:[password]@[host]:5432/postgres?sslmode=require

# SUPABASE_URL — your Supabase project URL
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# SUPABASE_JWT_SECRET — used to verify JWTs issued by Supabase Auth
# Found in: Supabase dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# GOOGLE_CLIENT_ID — OAuth2 client ID for Gmail integration
# Found in: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# GOOGLE_CLIENT_SECRET — OAuth2 client secret (never expose client-side)
# Found in: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret

# GEMINI_API_KEY — Gemini 2.5 Flash API key (server-side only)
# Never referenced in frontend or extension code.
# Found in: Google AI Studio → API Keys
GEMINI_API_KEY=your-gemini-api-key

# TOKEN_ENCRYPTION_KEY — Fernet key (base64) for encrypting Gmail tokens at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# See SECURITY.md for rotation procedure.
TOKEN_ENCRYPTION_KEY=your-fernet-key-base64

# FRONTEND_URL — your Vercel deployment URL
# In production: https://your-app.vercel.app
# In dev: http://localhost:3000
# Used by /gmail/callback redirect — never hardcode.
FRONTEND_URL=https://your-app.vercel.app

# EXTENSION_ORIGIN — the chrome-extension:// origin for your published extension
# In production: chrome-extension://<your-chrome-web-store-extension-id>
# In dev (unpacked): chrome-extension://<unpacked-extension-id>
# The ID changes between unpacked and published — update this when publishing.
EXTENSION_ORIGIN=chrome-extension://your-extension-id

# ALLOWED_ORIGINS — comma-separated list of origins allowed by CORS
# Must include FRONTEND_URL and EXTENSION_ORIGIN.
# In production: https://your-app.vercel.app,chrome-extension://<id>
# In dev: http://localhost:3000,chrome-extension://<unpacked-id>
ALLOWED_ORIGINS=https://your-app.vercel.app,chrome-extension://your-extension-id

# BACKEND_URL — public URL of this backend server
# In production (no domain yet): http://<droplet-ip>:8000
# Will become https://api.yourdomain.com once Caddy + domain are added.
BACKEND_URL=http://your-droplet-ip:8000

# SENTRY_DSN — optional; leave blank or omit to skip Sentry initialization
# Found in: Sentry dashboard → Project → Settings → Client Keys (DSN)
# Format: https://<key>@<org>.ingest.sentry.io/<project-id>
SENTRY_DSN=
