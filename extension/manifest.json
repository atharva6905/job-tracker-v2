{
  "manifest_version": 3,
  "name": "job-tracker-v2",
  "version": "1.0.0",
  "description": "Automatically tracks job applications. Zero manual entry.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.wd1.myworkdayjobs.com/*",
        "*://*.wd3.myworkdayjobs.com/*",
        "*://*.wd5.myworkdayjobs.com/*",
        "*://*.wd501.myworkdayjobs.com/*",
        "*://*.myworkday.com/*",
        "*://*.myworkdaysite.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost:3000/*",
      "https://job-tracker-v2-kappa.vercel.app/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Tracker"
  }
}